{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-start-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "triggers": {
    // Cloudflare cron is UTC-only. 12:00 UTC = 7am CDT / 6am CST — primary US morning window.
    // sendMorningBriefing filters recipients by their preferred_briefing_hour so only users
    // whose local hour ≈ now receive a push.
    "crons": ["0 12 * * *"]
  }
}
